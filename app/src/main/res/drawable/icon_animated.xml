<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/icon_svg">

    <!-- Vertical bar group goes UP -->
    <target android:name="verticalBarGroup" android:animation="@animator/avd_bar_up_in"/>
    <target android:name="verticalBarGroup" android:animation="@animator/avd_bar_up_settle1"/>
    <target android:name="verticalBarGroup" android:animation="@animator/avd_bar_up_settle2"/>

    <!-- Seam fades in as bar reaches the house -->
    <target android:name="verticalbarshadow" android:animation="@animator/avd_seam_alpha"/>

    <!-- Top pill: from LEFT + subtle fade -->
    <target android:name="horizontalbarTopGroup" android:animation="@animator/avd_eq_top_in_left"/>
    <target android:name="horizontalbarTopGroup" android:animation="@animator/avd_eq_top_fade"/>

    <!-- Bottom pill: from RIGHT + subtle fade -->
    <target android:name="horizontalbarBottomGroup" android:animation="@animator/avd_eq_bottom_in_right"/>
    <target android:name="horizontalbarBottomGroup" android:animation="@animator/avd_eq_bottom_fade"/>

</animated-vector>